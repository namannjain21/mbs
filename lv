df -khT

sudo lvextend -L +10G /dev/hpcsa/app1 
sudo lvs
df -khT

sudo resize2fs /dev/hpcsa/app1
df -khT

sudo lvextend -L +14G /dev/hpcsa/app2
sudo lvs
