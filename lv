sudo vgcreate hpcsa /dev/sdb /dev/sdc
sudo vgs 
sudo vgdisplay
sudo pvs ( also show VG's )

sudo lvcreate -n app1 -L 5G hpcsa
sudo lvs
sudo lvdisplay
sudo lvcreate -n app2 -L 10G hpcsa

sudo mkfs.ext4 /dev/hpcsa/app1
sudo mkfs.ext4 /dev/hpcsa/app2

sudo mkdir /app1
sudo mkdir /app2
sudo mount -t auto /dev/hpcsa/app1 /app1
sudo mount -t auto /dev/hpcsa/app2 /app2

sudo cp /etc/fstab /app1
sudo cp /etc/passwd /app1
